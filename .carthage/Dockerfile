# .carthage/Dockerfile — generated by /carthage-annex.
#
# Extends carthage-base with project-specific runtimes and tools. The base
# image already includes: git, tmux, curl, openssh-client, jq, ripgrep,
# Python 3.12, uv, Node.js LTS, and the Claude Code CLI.
#
# System packages go here (there is no `sudo` in the running container).
# Do NOT add a trailing `USER carthage` — the base image already sets it,
# and the entrypoint runs as that user.

FROM ghcr.io/speculative/carthage-base:v1

# Playwright headless chromium runtime libs. The v0.0 visual smoke test
# bounced off `libglib-2.0.so.0: cannot open shared object file` against
# the bare base image — these are the standard libs Playwright's
# chromium-headless-shell needs on a Debian-flavored host.
USER root
RUN apt-get update && apt-get install -y --no-install-recommends \
        libglib2.0-0 \
        libnss3 \
        libnspr4 \
        libdbus-1-3 \
        libatk1.0-0 \
        libatk-bridge2.0-0 \
        libcups2 \
        libdrm2 \
        libxkbcommon0 \
        libxcomposite1 \
        libxdamage1 \
        libxext6 \
        libxfixes3 \
        libxrandr2 \
        libgbm1 \
        libpango-1.0-0 \
        libcairo2 \
        libasound2t64 \
        libatspi2.0-0 \
        fonts-liberation \
    && rm -rf /var/lib/apt/lists/*

# code-server: browser-based VS Code, used to develop and manually test
# the Slidewright VS Code extension (v0.1+) inside the sandbox without
# needing host-side VS Code. Pinned for reproducibility; bump deliberately.
ARG CODE_SERVER_VERSION=4.117.0
RUN curl -fsSL https://code-server.dev/install.sh \
      | sh -s -- --version ${CODE_SERVER_VERSION} \
    && rm -rf /var/lib/apt/lists/*
USER carthage

WORKDIR /workspace
